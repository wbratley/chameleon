CHAMELEON_MY_DOMAIN=yourdomain.com
CHAMELEON_RELAY_HOSTNAME=mail.yourdomain.com
CHAMELEON_LISTEN_HOST=0.0.0.0
CHAMELEON_LISTEN_PORT=1025
CHAMELEON_MAX_MESSAGE_SIZE=26214400
CHAMELEON_API_HOST=127.0.0.1
CHAMELEON_API_PORT=8080
# Generate with: openssl rand -hex 32
CHAMELEON_API_TOKEN=CHANGE_ME_STRONG_RANDOM_SECRET
# REQUIRED — the relay will not start without this. Generate the keypair on the
# home server with: python -m chameleon_local keygen  (never generate it here),
# then paste the printed CHAMELEON_PUBLIC_KEY value below.
CHAMELEON_PUBLIC_KEY=
CHAMELEON_QUEUE_DB_PATH=/data/queue.db
# How long undelivered mail is retained before being secure-deleted. This is the
# window during which mail survives if the home server is offline. Lower it to
# reduce data-at-rest on the relay; raise it to tolerate longer outages.
CHAMELEON_QUEUE_RETAIN_MINUTES=1440
CHAMELEON_LOG_LEVEL=INFO
# Optional STARTTLS for inbound SMTP (leave blank to disable):
CHAMELEON_TLS_CERT_PATH=
CHAMELEON_TLS_KEY_PATH=
