CHAMELEON_RELAY_WS_URL=wss://relay.yourdomain.com/ws
# Must match CHAMELEON_API_TOKEN in the relay .env
CHAMELEON_RELAY_TOKEN=CHANGE_ME_STRONG_RANDOM_SECRET
CHAMELEON_MY_DOMAIN=yourdomain.com
# Path to private key file (Docker secret). Generate with: python -m chameleon_local keygen
CHAMELEON_PRIVATE_KEY_PATH=/run/secrets/chameleon_private_key
CHAMELEON_MAILDIR_PATH=/srv/mail/chameleon
CHAMELEON_ALIAS_DB_PATH=/srv/data/aliases.db
CHAMELEON_WEB_PORT=8080
CHAMELEON_LOG_LEVEL=INFO
